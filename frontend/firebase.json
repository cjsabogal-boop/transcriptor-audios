{
  "hosting": [
    {
      "site": "transcriptor-carlos-sabogal",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.zip",
          "headers": [
            {
              "key": "Content-Disposition",
              "value": "attachment"
            },
            {
              "key": "Content-Type",
              "value": "application/zip"
            }
          ]
        }
      ]
    },
    {
      "site": "transcriptor-hernando-2026",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.zip",
          "headers": [
            {
              "key": "Content-Disposition",
              "value": "attachment"
            },
            {
              "key": "Content-Type",
              "value": "application/zip"
            }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
